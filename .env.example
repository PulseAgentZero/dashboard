# Pulse dashboard — copy to .env.local and adjust for your environment.

# Backend API origin (no trailing slash). Default Pulse API dev server:
NEXT_PUBLIC_API_URL=http://localhost:8000

# The API must set FRONTEND_URL to this app's origin (scheme + host + port)
# for CORS and auth email links. Next.js dev defaults to port 3000:
#   FRONTEND_URL=http://localhost:3000
#
# Email verification and password reset require the API to have REDIS_URL and
# RESEND_API_KEY configured.
