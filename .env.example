# Entivia dashboard — copy to .env.local and adjust for your environment.

# Backend API origin (no trailing slash). Default Entivia API dev server:
NEXT_PUBLIC_API_URL=http://localhost:8000

# cloud — Entivia Cloud (hides self-hosted-only settings tabs)
# self_hosted — on-prem / Docker (shows LLM keys, license)
NEXT_PUBLIC_DEPLOYMENT_MODE=cloud

# Marketing copy for cloud Pro plan (pricing page)
NEXT_PUBLIC_PRO_PRICE_DISPLAY=₦40,000/month

# The API must set FRONTEND_URL to this app's origin (scheme + host + port)
# for CORS and auth email links. Next.js dev defaults to port 3000:
#   FRONTEND_URL=http://localhost:3000
#
# Email verification and password reset require the API to have REDIS_URL and
# RESEND_API_KEY configured.
